# Resend — transactional email
# 1. Sign up at https://resend.com
# 2. Verify campforcitycouncil.com in the Domains section (add the SPF/DKIM DNS records to your registrar)
# 3. Create an API key under API Keys and paste it below
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Resend Audience to add new signups to (for CSV export + future broadcasts).
# Create one at https://resend.com/audiences and paste its ID here.
# If left blank, signups still send emails but won't be added to an audience.
RESEND_AUDIENCE_ID=

# Optional overrides (defaults shown). Only set these if you want to change them.
# RESEND_FROM_ADDRESS="Steve Camp for City Council <noreply@campforcitycouncil.com>"
# RESEND_NOTIFY_TO=stevec@elementsarch.com,hello@spencercamp.com
# RESEND_REPLY_TO=stevec@elementsarch.com
